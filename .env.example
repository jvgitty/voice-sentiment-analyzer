# .env.example — copy to .env and fill in real values before running
# `docker compose up`. The .env file itself is gitignored.

# Inbound API key. Any non-empty string the analyzer should accept on
# `Authorization: Bearer <API_KEY>`. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=replace-me-with-a-random-string

# Transcription engine: "parakeet" (default, NeMo) or "whisper"
# (faster-whisper alternative). Both are baked into the Docker image.
TRANSCRIBER_ENGINE=parakeet

# When TRANSCRIBER_ENGINE=whisper, which faster-whisper model size to
# load. One of: tiny, base, small, medium, large-v3. Ignored for
# parakeet. Larger = slower + more accurate.
WHISPER_MODEL=small

# Window size in seconds for the time-windowed analysis section.
# 30 is a sensible default for a 1-3 minute voice note.
WINDOW_SECONDS=30

# Maximum audio file size the AudioFetcher will accept (bytes).
# Default is 50 MiB.
MAX_AUDIO_BYTES=52428800
